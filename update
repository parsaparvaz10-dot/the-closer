// ─── ROBUST JSON REPAIR ──────────────────────────────────────────────────────
function repairJSON(str) {
  let s = str;

  // Strip markdown fences
  s = s.replace(/```json\s*/g, "").replace(/```\s*/g, "");

  // Extract outermost JSON object
  const start = s.indexOf("{");
  if (start === -1) return null;

  // Find matching closing brace by counting depth
  let depth = 0, end = -1;
  for (let i = start; i < s.length; i++) {
    const c = s[i];
    if (c === "{") depth++;
    else if (c === "}") { depth--; if (depth === 0) { end = i; break; } }
    else if (c === '"') {
      // Skip string content, handling escapes
      i++;
      while (i < s.length && s[i] !== '"') { if (s[i] === "\\") i++; i++; }
    }
  }

  if (end === -1) {
    // Truncated JSON — try to close it
    s = s.substring(start);
    // Remove any trailing partial string value
    s = s.replace(/,\s*"[^"]*":\s*"[^"]*$/, "");
    s = s.replace(/,\s*"[^"]*":\s*$/, "");
    s = s.replace(/,\s*"[^"]*$/, "");
    s = s.replace(/,\s*$/, "");
    // Count unclosed braces and brackets
    let openBraces = 0, openBrackets = 0;
    let inStr = false;
    for (let i = 0; i < s.length; i++) {
      const c = s[i];
      if (c === '"' && (i === 0 || s[i-1] !== "\\")) inStr = !inStr;
      if (!inStr) {
        if (c === "{") openBraces++;
        else if (c === "}") openBraces--;
        else if (c === "[") openBrackets++;
        else if (c === "]") openBrackets--;
      }
    }
    // Close open brackets then braces
    for (let i = 0; i < openBrackets; i++) s += "]";
    for (let i = 0; i < openBraces; i++) s += "}";
  } else {
    s = s.substring(start, end + 1);
  }

  // Common repairs
  s = s.replace(/,\s*}/g, "}");        // trailing commas before }
  s = s.replace(/,\s*]/g, "]");        // trailing commas before ]
  s = s.replace(/'\s*:/g, '":');       // single-quoted keys
  s = s.replace(/:\s*'/g, ': "');      // single-quoted values
  s = s.replace(/'\s*,/g, '",');
  s = s.replace(/'\s*}/g, '"}');
  s = s.replace(/'\s*]/g, '"]');

  // Remove control characters except newlines and tabs inside strings
  s = s.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, "");

  // Fix common special chars that break JSON strings
  // Replace literal newlines inside strings
  s = s.replace(/"([^"]*?)"/g, (match, inner) => {
    const fixed = inner.replace(/\n/g, "\\n").replace(/\t/g, "\\t").replace(/\r/g, "\\r");
    return `"${fixed}"`;
  });

  return s;
}

// ─── API CALL HELPER (with retry on JSON failure) ────────────────────────────
async function callAgent(systemPrompt, userMessage, useWebSearch = true, images = [], maxTokens = 4096) {
  const content = [];
  for (const img of images) {
    content.push({ type: "image", source: { type: "base64", media_type: img.mediaType, data: img.data } });
  }
  content.push({ type: "text", text: userMessage });

  const body = {
    model: MODEL,
    max_tokens: maxTokens,
    system: systemPrompt,
    messages: [{ role: "user", content }],
  };
  if (useWebSearch) body.tools = [{ type: "web_search_20250305", name: "web_search" }];

  const res = await fetch(API_URL, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body),
  });

  if (!res.ok) {
    const err = await res.text();
    throw new Error(`API error ${res.status}: ${err}`);
  }

  const data = await res.json();
  const raw = (data.content?.filter(b => b.type === "text") || []).map(b => b.text).join("\n");

  // Attempt 1: direct parse after repair
  const repaired = repairJSON(raw);
  if (!repaired) throw new Error("No JSON object found in response");

  try {
    return JSON.parse(repaired);
  } catch (e1) {
    // Attempt 2: ask the model to fix its own broken JSON
    console.warn("JSON parse failed, attempting auto-repair via API...", e1.message);
    try {
      const fixRes = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: MODEL,
          max_tokens: maxTokens,
          system: "You are a JSON repair tool. The user will give you broken JSON. Fix it and return ONLY the valid JSON object. Do not add explanation, markdown, or backticks. Do not change any data values — only fix syntax errors (missing commas, unclosed braces/brackets, unescaped quotes, truncated strings). If data appears truncated, close the structure cleanly with reasonable placeholder values.",
          messages: [{ role: "user", content: `Fix this broken JSON:\n\n${repaired.substring(0, 12000)}` }],
        }),
      });
      if (fixRes.ok) {
        const fixData = await fixRes.json();
        const fixRaw = (fixData.content?.filter(b => b.type === "text") || []).map(b => b.text).join("\n");
        const fixRepaired = repairJSON(fixRaw);
        if (fixRepaired) {
          return JSON.parse(fixRepaired);
        }
      }
    } catch (e2) {
      console.warn("Auto-repair also failed:", e2.message);
    }

    // Attempt 3: last-ditch — try to extract partial data
    try {
      // Try parsing just up to where it breaks
      const partial = repaired.substring(0, 10000);
      // Find the last valid closing point
      for (let i = partial.length; i > 100; i--) {
        if (partial[i] === "}") {
          try {
            const slice = partial.substring(0, i + 1);
            const result = JSON.parse(repairJSON(slice) || slice);
            result._partial = true;
            return result;
          } catch { /* keep trying */ }
        }
      }
    } catch { /* give up */ }

    throw new Error(`JSON parse failed after all repair attempts. Original error: ${e1.message}`);
  }
}

// ─── IMAGE UTILS ─────────────────────────────────────────────────────────────
function fileToBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => {
      const base64 = reader.result.split(",")[1];
      resolve({ data: base64, mediaType: file.type, name: file.name, size: file.size, preview: reader.result });
    };
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

